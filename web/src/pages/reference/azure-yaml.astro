    shell: sh
    continueOnError: true  # Don't fail if hook fails
    
  # Interactive hook (binds to stdin/stdout)
  prerun:
    run: ./scripts/setup.sh
    shell: bash
    interactive: true
    
  # Platform-specific hooks
  prerun:
