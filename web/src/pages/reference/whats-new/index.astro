---
import Layout from '../../../components/Layout.astro';
---

<Layout title="What's New" description="Latest updates to azd-app CLI">
  <div class="max-w-4xl mx-auto px-4 py-12">
    <!-- Header -->
    <div class="mb-12">
      <h1 class="text-4xl font-bold mb-4">What's New</h1>
      <p class="text-xl text-neutral-600 dark:text-neutral-400">
        Latest updates and features in the azd-app CLI extension.
      </p>
      <div class="mt-4">
        <a 
          href="/azd-app/reference/changelog/" 
          class="text-blue-600 dark:text-blue-400 hover:underline"
        >
          View full changelog →
        </a>
      </div>
    </div>

    <!-- Highlights -->
    <div class="mb-12 p-6 bg-linear-to-r from-blue-50 to-purple-50 dark:from-blue-900/20 dark:to-purple-900/20 rounded-lg border border-blue-200 dark:border-blue-800">
      <h2 class="text-xl font-bold mb-4">🎉 Recent Highlights</h2>
      <ul class="space-y-2 text-neutral-700 dark:text-neutral-300">
        <li class="flex items-start gap-2">
          <span class="text-green-500">✓</span>
          <span><strong>MCP Server</strong> - AI assistants can now debug your services</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-500">✓</span>
          <span><strong>Production Health Checks</strong> - Circuit breaker, rate limiting, caching</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-500">✓</span>
          <span><strong>Azure Functions & Logic Apps</strong> - Full support for serverless workloads</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-500">✓</span>
          <span><strong>Lifecycle Hooks</strong> - Run scripts before/after services start</span>
        </li>
      </ul>
    </div>

    <!-- Latest Releases -->
    <div class="space-y-8">
      
    <article class="mb-12 pb-8 border-b-2 border-blue-200 dark:border-blue-800">
      <header class="flex items-center gap-4 mb-4">
        <h2 class="text-2xl font-bold text-neutral-900 dark:text-white">
          v0.11.4
        </h2>
        <time class="text-sm text-neutral-500" datetime="2026-01-30">2026-01-30</time>
        <span class="px-2 py-1 text-xs font-medium bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-300 rounded">Latest</span>
      </header>
      <ul class="space-y-1">
        
        <li class="flex items-start gap-3 py-2">
          <span class="shrink-0 text-lg">📝</span>
          <span class="text-neutral-700 dark:text-neutral-300">Remove shorthand for --exclude flag and update dependencies (<a href="https://github.com/jongio/azd-app/pull/123" class="text-blue-600 dark:text-blue-400 hover:underline" target="_blank">#123</a>) (<a href="https://github.com/jongio/azd-app/commit/2f2f956" class="text-neutral-500 hover:underline" target="_blank">2f2f956</a>)</span>
        </li>
        <li class="flex items-start gap-3 py-2">
          <span class="shrink-0 text-lg">🔧</span>
          <span class="text-neutral-700 dark:text-neutral-300">chore: update registry for v0.11.3 (<a href="https://github.com/jongio/azd-app/commit/98cf75a" class="text-neutral-500 hover:underline" target="_blank">98cf75a</a>)</span>
        </li>
      </ul>
    </article>

    <article class="mb-12 ">
      <header class="flex items-center gap-4 mb-4">
        <h2 class="text-2xl font-bold text-neutral-900 dark:text-white">
          v0.11.3
        </h2>
        <time class="text-sm text-neutral-500" datetime="2026-01-27">2026-01-27</time>
        
      </header>
      <ul class="space-y-1">
        
        <li class="flex items-start gap-3 py-2">
          <span class="shrink-0 text-lg">📝</span>
          <span class="text-neutral-700 dark:text-neutral-300">Refactor environment variable handling and enhance CLI documentation (<a href="https://github.com/jongio/azd-app/pull/120" class="text-blue-600 dark:text-blue-400 hover:underline" target="_blank">#120</a>) (<a href="https://github.com/jongio/azd-app/commit/5bd8dd7" class="text-neutral-500 hover:underline" target="_blank">5bd8dd7</a>)</span>
        </li>
        <li class="flex items-start gap-3 py-2">
          <span class="shrink-0 text-lg">🔧</span>
          <span class="text-neutral-700 dark:text-neutral-300">chore: update registry for v0.11.2 (<a href="https://github.com/jongio/azd-app/commit/62e3481" class="text-neutral-500 hover:underline" target="_blank">62e3481</a>)</span>
        </li>
      </ul>
    </article>

    <article class="mb-12 ">
      <header class="flex items-center gap-4 mb-4">
        <h2 class="text-2xl font-bold text-neutral-900 dark:text-white">
          v0.11.2
        </h2>
        <time class="text-sm text-neutral-500" datetime="2026-01-24">2026-01-24</time>
        
      </header>
      <ul class="space-y-1">
        
        <li class="flex items-start gap-3 py-2">
          <span class="shrink-0 text-lg">✨</span>
          <span class="text-neutral-700 dark:text-neutral-300">feat: Update CLI reference for `azd app run` command and add new flags (<a href="https://github.com/jongio/azd-app/pull/117" class="text-blue-600 dark:text-blue-400 hover:underline" target="_blank">#117</a>) (<a href="https://github.com/jongio/azd-app/commit/9730450" class="text-neutral-500 hover:underline" target="_blank">9730450</a>)</span>
        </li>
        <li class="flex items-start gap-3 py-2">
          <span class="shrink-0 text-lg">🔧</span>
          <span class="text-neutral-700 dark:text-neutral-300">chore: update registry for v0.11.1 (<a href="https://github.com/jongio/azd-app/commit/c5d2051" class="text-neutral-500 hover:underline" target="_blank">c5d2051</a>)</span>
        </li>
      </ul>
    </article>
    </div>

    <!-- CTA -->
    <div class="mt-12 p-6 bg-neutral-100 dark:bg-neutral-800 rounded-lg text-center">
      <h3 class="text-lg font-semibold mb-2">Ready to try it?</h3>
      <p class="text-neutral-600 dark:text-neutral-400 mb-4">
        Get started with the latest version of azd-app in minutes.
      </p>
      <a 
        href="/azd-app/quick-start/"
        class="inline-flex items-center gap-2 px-6 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors"
      >
        Quick Start Guide →
      </a>
    </div>
  </div>
</Layout>
