---
/**
 * Layout Component
 * Main structural foundation for all pages on the azd-app website.
 * Uses shared Layout/Header/Footer from @jongio/azd-web-core.
 * Orchestrates Sidebar (optional) and page-specific features.
 */
import SharedLayout from '@jongio/azd-web-core/components/Layout.astro';
import SharedHeader from '@jongio/azd-web-core/components/Header.astro';
import SharedFooter from '@jongio/azd-web-core/components/Footer.astro';
import SuiteNav from '@jongio/azd-web-core/components/SuiteNav.astro';
import MobileMenu from './MobileMenu.astro';
import Sidebar from './Sidebar.astro';
import Lightbox from './Lightbox.astro';
import '../styles/global.css';

interface SidebarItem {
  label: string;
  href: string;
  badge?: {
    text: string;
    variant: 'default' | 'new' | 'beta' | 'deprecated';
  };
  items?: SidebarItem[];
}

interface SidebarSection {
  title: string;
  id: string;
  collapsible?: boolean;
  defaultExpanded?: boolean;
  items: SidebarItem[];
}

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface PageLink {
  label: string;
  href: string;
}

interface Props {
  /** Page variant */
  variant?: 'default' | 'docs' | 'full-width' | 'landing';
  /** Page title */
  title: string;
  /** Page description */
  description?: string;
  /** Show sidebar */
  showSidebar?: boolean;
  /** Sidebar navigation structure */
  sidebarSections?: SidebarSection[];
  /** Breadcrumb items */
  breadcrumb?: BreadcrumbItem[];
  /** Previous page link */
  prevPage?: PageLink;
  /** Next page link */
  nextPage?: PageLink;
  /** Custom content class */
  contentClass?: string;
}

const {
  variant = 'default',
  title,
  description = 'azd app - Azure Developer CLI Extension for running local development environments',
  showSidebar = false,
  sidebarSections = [],
  breadcrumb = [],
  prevPage,
  nextPage,
  contentClass = '',
} = Astro.props;

const currentPath = Astro.url.pathname;
const fullTitle = title === 'Home' ? 'azd app | Azure Developer CLI Extension' : `${title} | azd app`;
const base = import.meta.env.BASE_URL;

const navLinks = [
  { label: 'Quick Start', href: `${base}quick-start/` },
  { label: 'MCP Server', href: `${base}mcp/`, badge: 'AI' },
  { label: 'Tour', href: `${base}tour/` },
  { label: 'Examples', href: `${base}examples/` },
  { label: 'Reference', href: `${base}reference/cli/` },
];
---

<SharedLayout
  title={fullTitle}
  description={description}
  extensionName="app"
>
  <Fragment slot="head">
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  </Fragment>

  <SuiteNav currentExtension="app" hubUrl="https://jongio.github.io/azd-extensions/" />

  <SharedHeader
    extensionName="app"
    navLinks={navLinks}
    githubUrl="https://github.com/jongio/azd-app"
  />

  <!-- Mobile Menu (page-specific with icons and full nav) -->
  <MobileMenu currentPath={currentPath} />

  <!-- Main Layout Container -->
  <div class:list={['layout', `layout--${variant}`]}>
    <div class="layout-container">
      {showSidebar && sidebarSections.length > 0 && (
        <Sidebar sections={sidebarSections} currentPath={currentPath} />
      )}

      <!-- Main Content -->
      <main id="main-content" class:list={['layout-main', contentClass]} role="main">
        <!-- Breadcrumb -->
        {breadcrumb.length > 0 && (
          <nav aria-label="Breadcrumb" class="breadcrumb">
            <ol class="breadcrumb-list">
              {breadcrumb.map((item, index) => (
                <li class="breadcrumb-item">
                  {item.href && index < breadcrumb.length - 1 ? (
                    <>
                      <a href={item.href} class="breadcrumb-link">{item.label}</a>
                      <span class="breadcrumb-separator" aria-hidden="true">/</span>
                    </>
                  ) : (
                    <span aria-current="page" class="breadcrumb-current">{item.label}</span>
                  )}
                </li>
              ))}
            </ol>
          </nav>
        )}

        <!-- Page Content -->
        <article class="layout-content">
          <slot />
        </article>

        <!-- Page Navigation (Prev/Next) -->
        {(prevPage || nextPage) && (
          <nav aria-label="Page navigation" class="page-nav">
            {prevPage ? (
              <a href={prevPage.href} class="page-nav-link page-nav-link--prev" rel="prev">
                <span class="page-nav-direction">Previous</span>
                <span class="page-nav-title">{prevPage.label}</span>
              </a>
            ) : (
              <div></div>
            )}
            {nextPage && (
              <a href={nextPage.href} class="page-nav-link page-nav-link--next" rel="next">
                <span class="page-nav-direction">Next</span>
                <span class="page-nav-title">{nextPage.label}</span>
              </a>
            )}
          </nav>
        )}
      </main>
    </div>
  </div>

  <!-- Footer -->
  <SharedFooter
    extensionName="app"
    githubUrl="https://github.com/jongio/azd-app"
    hubUrl="https://jongio.github.io/azd-extensions/"
  />

  <!-- Lightbox (global, for screenshots) -->
  <Lightbox />
</SharedLayout>

<style is:global>
  /* Layout */
  .layout {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .layout-container {
    display: flex;
    flex: 1;
  }

  .layout-main {
    flex: 1;
    padding: var(--space-8) var(--space-6);
    max-width: 100%;
  }

  @media (min-width: 1024px) {
    .layout-main {
      padding: var(--space-12) var(--space-8);
    }
  }

  .layout--default .layout-main,
  .layout--landing .layout-main {
    max-width: 1280px;
    margin: 0 auto;
    width: 100%;
  }

  .layout--docs .layout-main {
    max-width: 768px;
  }

  .layout--full-width .layout-main {
    padding: 0;
    max-width: none;
  }

  .layout-content {
    min-height: 50vh;
  }

  /* Breadcrumb */
  .breadcrumb {
    margin-bottom: var(--space-6);
    font-size: var(--text-xs);
  }

  .breadcrumb-list {
    display: flex;
    flex-wrap: wrap;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .breadcrumb-item {
    display: flex;
    align-items: center;
  }

  .breadcrumb-link {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .breadcrumb-link:hover {
    color: var(--color-text);
    text-decoration: underline;
  }

  .breadcrumb-link:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-radius: 0.125rem;
  }

  .breadcrumb-separator {
    margin: 0 var(--space-2);
    color: var(--color-text-muted);
  }

  .breadcrumb-current {
    color: var(--color-text);
    font-weight: 500;
  }

  /* Page Navigation */
  .page-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-top: var(--space-16);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 480px) {
    .page-nav {
      grid-template-columns: 1fr;
    }
  }

  .page-nav-link {
    display: flex;
    flex-direction: column;
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: border-color var(--transition-fast), background-color var(--transition-fast);
  }

  .page-nav-link:hover {
    border-color: var(--color-primary);
    background-color: var(--color-surface);
  }

  .page-nav-link:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .page-nav-link--prev {
    align-items: flex-start;
  }

  .page-nav-link--next {
    align-items: flex-end;
    text-align: right;
  }

  @media (max-width: 480px) {
    .page-nav-link--next {
      align-items: flex-start;
      text-align: left;
    }
  }

  .page-nav-direction {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .page-nav-title {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-primary);
  }

  /* Screen reader only */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
