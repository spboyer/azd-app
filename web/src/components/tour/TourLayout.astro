---
/**
 * TourLayout Component
 * 
 * Main layout wrapper for guided tour pages.
 * Includes the progress sidebar and main content area.
 * Uses shared Layout/Header/Footer from @jongio/azd-web-core.
 */
import SharedLayout from '@jongio/azd-web-core/components/Layout.astro';
import SharedHeader from '@jongio/azd-web-core/components/Header.astro';
import SharedFooter from '@jongio/azd-web-core/components/Footer.astro';
import SuiteNav from '@jongio/azd-web-core/components/SuiteNav.astro';
import MobileMenu from '../MobileMenu.astro';
import Lightbox from '../Lightbox.astro';
import TourProgressSidebar from './TourProgressSidebar.astro';
import { tourSteps, getTotalEstimatedTime } from '../../data/tour-steps';
import '../../styles/global.css';

interface Props {
  /** Page title */
  title: string;
  /** Page description */
  description?: string;
  /** Current step number (0 for overview) */
  currentStep?: number;
}

const {
  title,
  description = 'Guided tour of azd-app features',
  currentStep = 0,
} = Astro.props;

const currentPath = Astro.url.pathname;
const fullTitle = `${title} | azd-app Guided Tour`;
const totalTime = getTotalEstimatedTime();
const base = import.meta.env.BASE_URL;

const navLinks = [
  { label: 'Quick Start', href: `${base}quick-start/` },
  { label: 'MCP Server', href: `${base}mcp/`, badge: 'AI' },
  { label: 'Tour', href: `${base}tour/` },
  { label: 'Examples', href: `${base}examples/` },
  { label: 'Reference', href: `${base}reference/cli/` },
];
---

<SharedLayout
  title={fullTitle}
  description={description}
  extensionName="app"
>
  <Fragment slot="head">
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  </Fragment>

  <SuiteNav currentExtension="app" hubUrl="https://jongio.github.io/azd-extensions/" />

  <SharedHeader
    extensionName="app"
    navLinks={navLinks}
    githubUrl="https://github.com/jongio/azd-app"
  />

  <!-- Mobile Menu -->
  <MobileMenu currentPath={currentPath} />

  <div class="tour-layout">
    <!-- Tour Layout Container -->
    <div class="tour-container">
      <!-- Progress Sidebar -->
      <TourProgressSidebar 
        steps={tourSteps} 
        currentStep={currentStep}
        totalTime={totalTime}
      />

      <!-- Main Content -->
      <main id="main-content" class="tour-main" role="main">
        <slot />
      </main>
    </div>

    <!-- Mobile Sidebar Trigger -->
    <button 
      type="button"
      class="tour-sidebar-trigger"
      aria-label="Show tour progress"
      aria-expanded="false"
      aria-controls="tour-sidebar"
      data-tour-sidebar-trigger
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
      </svg>
    </button>

    <!-- Mobile Sidebar Overlay -->
    <div class="tour-sidebar-overlay" data-tour-sidebar-overlay hidden></div>
  </div>

  <!-- Footer -->
  <SharedFooter
    extensionName="app"
    githubUrl="https://github.com/jongio/azd-app"
    hubUrl="https://jongio.github.io/azd-extensions/"
  />

  <!-- Lightbox -->
  <Lightbox />

  <script>
    function initTourSidebar(): void {
      const trigger = document.querySelector<HTMLButtonElement>('[data-tour-sidebar-trigger]');
      const sidebar = document.querySelector<HTMLElement>('[data-tour-sidebar]');
      const overlay = document.querySelector<HTMLElement>('[data-tour-sidebar-overlay]');
      const closeBtn = document.querySelector<HTMLButtonElement>('[data-tour-sidebar-close]');

      if (!trigger || !sidebar || !overlay) return;

      function openSidebar(): void {
        sidebar?.classList.add('tour-sidebar--open');
        overlay?.removeAttribute('hidden');
        trigger?.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
        const firstFocusable = sidebar?.querySelector<HTMLElement>('a, button');
        firstFocusable?.focus();
      }

      function closeSidebar(): void {
        sidebar?.classList.remove('tour-sidebar--open');
        overlay?.setAttribute('hidden', '');
        trigger?.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
        trigger?.focus();
      }

      trigger.addEventListener('click', openSidebar);
      overlay.addEventListener('click', closeSidebar);
      closeBtn?.addEventListener('click', closeSidebar);

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && sidebar?.classList.contains('tour-sidebar--open')) {
          closeSidebar();
        }
      });
    }

    // Initialize
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initTourSidebar);
    } else {
      initTourSidebar();
    }

    document.addEventListener('astro:after-swap', initTourSidebar);
  </script>
</SharedLayout>

<style is:global>
  /* Tour Layout */
  .tour-layout {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .tour-container {
    display: flex;
    flex: 1;
  }

  .tour-main {
    flex: 1;
    padding: var(--space-8) var(--space-6);
    max-width: 100%;
  }

  @media (min-width: 1024px) {
    .tour-main {
      padding: var(--space-12) var(--space-8);
      max-width: 800px;
      margin: 0 auto;
    }
  }

  /* Mobile Sidebar Trigger */
  .tour-sidebar-trigger {
    display: none;
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: var(--z-overlay);
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--color-primary);
    color: white;
    border: none;
    box-shadow: var(--shadow-lg);
    cursor: pointer;
    align-items: center;
    justify-content: center;
    transition: background-color var(--transition-fast), transform var(--transition-fast);
  }

  .tour-sidebar-trigger:hover {
    background: color-mix(in srgb, var(--color-primary) 80%, black);
    transform: scale(1.05);
  }

  .tour-sidebar-trigger:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  @media (max-width: 1023px) {
    .tour-sidebar-trigger {
      display: flex;
    }
  }

  /* Mobile Sidebar Overlay */
  .tour-sidebar-overlay {
    position: fixed;
    inset: 0;
    z-index: var(--z-overlay);
    background: rgba(0, 0, 0, 0.5);
    opacity: 0;
    transition: opacity 200ms ease-out;
  }

  .tour-sidebar-overlay:not([hidden]) {
    opacity: 1;
  }

  /* Screen reader only */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
